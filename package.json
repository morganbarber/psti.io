{
    "name": "pastebin",
    "version": "1.0.0",
    "private": true,
    "description": "Enterprise-level security-focused pastebin for hackers",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "clean": "turbo run clean && rm -rf node_modules",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
        "deploy": "sst deploy"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "devDependencies": {
        "@types/node": "^26.0.1",
        "prettier": "^3.8.5",
        "sst": "^4.17.0",
        "turbo": "^2.10.0",
        "typescript": "6.0.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "packageManager": "npm@11.17.0",
    "dependencies": {
        "@tailwindcss/postcss": "^4.3.1",
        "eslint": "^9.39.4",
        "tailwindcss": "^4.3.1"
    }
}
